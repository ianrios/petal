{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["es2020"],
    "types": ["vitest/globals"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "esnext",
    "target": "esnext",
    "strict": true,
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts"],
  "references": []
}
